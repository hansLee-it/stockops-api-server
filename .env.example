# StockOps API Environment Variables
# Public-safe template only. Copy to .env locally or inject through a secret manager.
# Never commit real passwords, API keys, webhook URLs, cloud credentials, or private certificates.

# Runtime profile
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
STOCKOPS_ENVIRONMENT=local

# Database
STOCKOPS_DATASOURCE_URL=jdbc:postgresql://localhost:5432/stockops
STOCKOPS_DATASOURCE_USERNAME=stockops
STOCKOPS_DATASOURCE_PASSWORD=

# JWT
# Use a long random value from a password manager or secret manager.
JWT_SECRET=
JWT_EXPIRATION=86400000

# CORS
STOCKOPS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis / rate limit
STOCKOPS_REDIS_ENABLED=true
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Telemetry ingestion
# Choose one live telemetry source per environment to avoid duplicate processing.
# MQTT mode: STOCKOPS_MQTT_INGESTION_ENABLED=true and STOCKOPS_SQS_INGESTION_ENABLED=false.
# SQS mode:  STOCKOPS_MQTT_INGESTION_ENABLED=false and STOCKOPS_SQS_INGESTION_ENABLED=true.
# Raw measurements are not stored; normalized recent readings go to Redis and alert events go to DB.
STOCKOPS_MQTT_INGESTION_ENABLED=true
STOCKOPS_MQTT_INGESTION_BROKER_URL=tcp://localhost:1883
STOCKOPS_MQTT_INGESTION_QOS=1
STOCKOPS_MQTT_INGESTION_CLIENT_ID=
STOCKOPS_SQS_INGESTION_ENABLED=false
STOCKOPS_SQS_INGESTION_QUEUE_URL=
STOCKOPS_SQS_INGESTION_REGION=ap-northeast-2
STOCKOPS_SQS_INGESTION_MAX_MESSAGES=10
STOCKOPS_SQS_INGESTION_WAIT_TIME_SECONDS=20
STOCKOPS_SQS_INGESTION_VISIBILITY_TIMEOUT_SECONDS=30
STOCKOPS_SQS_INGESTION_ERROR_BACKOFF_MILLIS=5000

# Recent sensor reading cache (shared Redis window served over REST)
STOCKOPS_SENSOR_CACHE_RECENT_WINDOW=10m
STOCKOPS_SENSOR_CACHE_KEY_TTL=15m

# Sensimul HTTP integration
STOCKOPS_SENSIMUL_BASE_URL=http://localhost:18080

# Internal AI module integration
STOCKOPS_AI_SERVICE_URL=http://localhost:8000
STOCKOPS_AI_SERVICE_API_KEY=

# Gemini provider, optional
GEMINI_ENABLED=false
GEMINI_API_KEY=

# AWS credentials for the SDK default credential chain — used by SQS ingestion and any AWS
# client that does NOT have a dedicated provider. Prefer an IAM role / workload identity (IRSA)
# on AWS and leave these blank there. For local testing without a role, export real values
# (and AWS_SESSION_TOKEN if using temporary credentials). Never commit real key values.
#
# WARNING: do NOT set these to target Bedrock in a different AWS account. The SDK default chain
# picks up AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY ahead of IRSA, so they hijack EVERY AWS client
# in the JVM — including the cross-account SQS subscriber, which then gets a 403. For a separate
# Bedrock account use the dedicated STOCKOPS_BEDROCK_AWS_* keys below instead.
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS Bedrock provider, optional
# Prefer IAM role / workload identity in deployed environments. Do not commit AWS access keys.
STOCKOPS_BEDROCK_ENABLED=false
STOCKOPS_BEDROCK_REGION=ap-northeast-2
# Dedicated Bedrock credentials. Set these (NOT the global AWS_ACCESS_KEY_ID above) when Bedrock
# must target a different AWS account than SQS ingestion — they are scoped to the Bedrock clients
# only, so SQS keeps using the default chain (IRSA). Leave blank to let Bedrock use the default
# chain too (e.g. when Bedrock shares the deployment account via IRSA).
STOCKOPS_BEDROCK_AWS_ACCESS_KEY_ID=
STOCKOPS_BEDROCK_AWS_SECRET_ACCESS_KEY=
STOCKOPS_BEDROCK_MODEL_ID=
STOCKOPS_BEDROCK_INFERENCE_PROFILE_ARN=
STOCKOPS_BEDROCK_KNOWLEDGE_BASE_ID=
STOCKOPS_BEDROCK_AGENT_ID=
STOCKOPS_BEDROCK_AGENT_ALIAS_ID=
# Direct Converse tool-use assistant (POST /api/v1/ai/bedrock/assistant).
# Guardrail restricts answers to the StockOps domain; applied only when BOTH are set.
STOCKOPS_BEDROCK_GUARDRAIL_ID=
STOCKOPS_BEDROCK_GUARDRAIL_VERSION=
STOCKOPS_BEDROCK_MAX_TOOL_TURNS=5
# Inference tuning applied to every Converse request (lower temperature => more deterministic).
STOCKOPS_BEDROCK_MAX_OUTPUT_TOKENS=1200
STOCKOPS_BEDROCK_TEMPERATURE=0.2
# Optional assistant system-prompt override (single line). Leave blank to use the built-in
# Korean StockOps prompt (BedrockConverseOrchestrator.DEFAULT_SYSTEM_PROMPT); set a value to
# tune tone/format without a redeploy.
STOCKOPS_BEDROCK_SYSTEM_PROMPT=
# Knowledge Base (managed RAG over S3 ops docs, Titan V2 embeddings + Aurora pgvector).
# Set the KB id to enable ops-doc grounding; left blank, the assistant runs tool-use only.
# STOCKOPS_BEDROCK_KNOWLEDGE_BASE_ID is set above.
STOCKOPS_AI_OPS_SUMMARY_SCHEDULE_ENABLED=false
STOCKOPS_AI_OPS_SUMMARY_CRON=0 0 8 * * ?
STOCKOPS_AI_RAG_RATE_LIMIT=10

# Google Vertex AI provider, optional
# For local development, prefer application default credentials outside the repository.
STOCKOPS_VERTEX_AI_ENABLED=false
STOCKOPS_VERTEX_AI_PROJECT_ID=
STOCKOPS_VERTEX_AI_LOCATION=us-central1
STOCKOPS_VERTEX_AI_MODEL_ID=gemini-2.5-flash
STOCKOPS_VERTEX_AI_CREDENTIALS_JSON=

# Actuator / Prometheus exposure
STOCKOPS_ACTUATOR_EXPOSURE=health,info,prometheus
STOCKOPS_ACTUATOR_HEALTH_SHOW_DETAILS=never
# true only behind private networking / reverse-proxy allowlist; default keeps the endpoint authenticated
STOCKOPS_ACTUATOR_PROMETHEUS_PUBLIC=false

# Request log level override
STOCKOPS_REQUEST_LOG_LEVEL=INFO
